{
  "name": "sympackt",
  "version": "0.1.0",
  "private": true,
  "description": "Sample pack manager for the Elektron Syntakt",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "bash scripts/download-default-pack.sh",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "elektron",
    "sympakt",
    "sample-pack",
    "audio",
    "web-audio"
  ],
  "license": "MIT",
  "dependencies": {
    "fflate": "^0.8.2",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "rollup-plugin-minify-html-literals-v3": "^1.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-minify": "^2.1.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
